PATCH_LIST=9997,4015                                                                                        # List of patch IDs to be installed (comma separated)
GUARDIUM_MINOR_VERSION=12.2                                                                                 # Guardium minor version of lab release
IBM_REGISTR_KEY=                                                                                            # IBM container registry API key (required for VA lab- https://myibm.ibm.com/products-services/containerlibrary)
